<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mithinti Yedukondalu — Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600&family=Space+Mono&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0a0a;--accent:#00bfff;--accent2:#1e90ff;--glow:rgba(0,191,255,0.4);--glass-bg:rgba(255,255,255,0.06);--glass-border:rgba(0,191,255,0.25);--text:#e8f4ff;--muted:#7aa5c0;}
.theme-electric{--accent:#00bfff;--accent2:#1e90ff;--glow:rgba(0,191,255,0.4);--glass-border:rgba(0,191,255,0.25);}
.theme-neon{--accent:#00ffcc;--accent2:#00e5ff;--glow:rgba(0,255,204,0.4);--glass-border:rgba(0,255,204,0.25);}
.theme-violet{--accent:#7b5fff;--accent2:#a855f7;--glow:rgba(123,95,255,0.4);--glass-border:rgba(123,95,255,0.25);}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Rajdhani',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;cursor:none;}
#spotlight{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:2;}
#cursor{position:fixed;width:10px;height:10px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:screen;transition:width .15s,height .15s;}
#cursor-ring{position:fixed;width:38px;height:38px;border:1.5px solid var(--accent);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);opacity:.55;transition:width .2s,height .2s;}
#cursor-trail{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9996;}
#bg-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;}
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:18px 5%;display:flex;align-items:center;justify-content:space-between;background:rgba(10,10,10,.7);backdrop-filter:blur(20px);border-bottom:1px solid var(--glass-border);transition:background .3s;}
.nav-logo{font-family:'Orbitron',monospace;font-size:1.1rem;font-weight:900;color:var(--accent);letter-spacing:.15em;text-shadow:0 0 18px var(--glow);}
.nav-links{display:flex;gap:32px;list-style:none;}
.nav-links a{font-family:'Rajdhani',sans-serif;font-size:.95rem;letter-spacing:.1em;color:var(--muted);text-decoration:none;text-transform:uppercase;position:relative;transition:color .25s;}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--accent);transition:width .3s;}
.nav-links a:hover{color:var(--accent);}
.nav-links a:hover::after{width:100%;}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:none;}
.hamburger span{display:block;width:24px;height:2px;background:var(--accent);}
#theme-btn{position:fixed;bottom:32px;right:32px;z-index:200;width:52px;height:52px;border-radius:50%;background:var(--glass-bg);border:1px solid var(--glass-border);backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:center;cursor:none;box-shadow:0 0 18px var(--glow);transition:box-shadow .3s,transform .4s;}
#theme-btn:hover{box-shadow:0 0 36px var(--glow);transform:rotate(90deg) scale(1.1);}
#theme-btn svg{width:22px;height:22px;fill:var(--accent);}
section{position:relative;z-index:3;}
#hero{min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:0 5%;overflow:hidden;}
.hero-content{position:relative;z-index:4;}
.hero-tag{font-family:'Space Mono',monospace;font-size:.8rem;letter-spacing:.3em;color:var(--accent);margin-bottom:24px;opacity:0;animation:fadeUp .6s .3s forwards;}
.hero-name{font-family:'Orbitron',monospace;font-size:clamp(2.2rem,6vw,5.5rem);font-weight:900;line-height:1.1;color:#fff;text-shadow:0 0 40px var(--glow),0 0 80px rgba(0,191,255,.15);opacity:0;animation:fadeUp .7s .5s forwards;margin-bottom:8px;display:inline-block;will-change:transform;}
.hero-name span{color:var(--accent);}
.hero-btns{display:flex;gap:18px;justify-content:center;flex-wrap:wrap;opacity:0;animation:fadeUp .7s .9s forwards;}
.btn-primary,.btn-outline{padding:14px 36px;border-radius:50px;font-family:'Rajdhani',sans-serif;font-size:1rem;letter-spacing:.15em;font-weight:600;text-transform:uppercase;text-decoration:none;cursor:none;position:relative;overflow:hidden;display:inline-block;}
.btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#000;box-shadow:0 0 24px var(--glow);transition:transform .25s,box-shadow .25s;}
.btn-primary::before{content:'';position:absolute;top:-50%;left:-60%;width:200%;height:200%;background:rgba(255,255,255,.18);transform:rotate(25deg) translateX(-100%);transition:transform .5s;}
.btn-primary:hover::before{transform:rotate(25deg) translateX(100%);}
.btn-primary:hover{transform:translateY(-4px) scale(1.05);box-shadow:0 0 48px var(--glow);}
.btn-outline{border:1px solid var(--glass-border);color:var(--accent);background:var(--glass-bg);backdrop-filter:blur(10px);transition:all .25s;}
.btn-outline:hover{border-color:var(--accent);background:rgba(0,191,255,.1);transform:translateY(-4px) scale(1.05);box-shadow:0 0 24px var(--glow);}
.orb{position:absolute;border-radius:50%;pointer-events:none;animation:floatOrb var(--d,8s) ease-in-out infinite alternate;}
.orb1{width:280px;height:280px;top:8%;left:3%;background:radial-gradient(circle,rgba(0,191,255,.09),transparent 70%);--d:9s;}
.orb2{width:220px;height:220px;bottom:12%;right:5%;background:radial-gradient(circle,rgba(30,144,255,.08),transparent 70%);--d:7s;}
.orb3{width:150px;height:150px;top:55%;left:18%;background:radial-gradient(circle,rgba(0,255,204,.06),transparent 70%);--d:11s;}
@keyframes floatOrb{from{transform:translateY(0) scale(1);}to{transform:translateY(-45px) scale(1.12);}}
.scroll-hint{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0;animation:fadeUp .7s 1.2s forwards;}
.scroll-hint span{font-size:.7rem;letter-spacing:.2em;color:var(--muted);text-transform:uppercase;}
.scroll-line{width:1px;height:50px;background:linear-gradient(to bottom,var(--accent),transparent);animation:scrollPulse 2s infinite;}
.glass{background:var(--glass-bg);backdrop-filter:blur(16px);border:1px solid var(--glass-border);border-radius:20px;box-shadow:0 8px 40px rgba(0,0,0,.4);transform-style:preserve-3d;will-change:transform;}
.section-inner{max-width:1100px;margin:0 auto;padding:100px 5%;}
.section-label{font-family:'Space Mono',monospace;font-size:.75rem;letter-spacing:.35em;color:var(--accent);text-transform:uppercase;margin-bottom:12px;}
.section-title{font-family:'Orbitron',monospace;font-size:clamp(1.6rem,4vw,2.8rem);font-weight:700;color:#fff;margin-bottom:56px;position:relative;}
.section-title::after{content:'';display:block;width:0;height:3px;background:linear-gradient(to right,var(--accent),transparent);margin-top:14px;border-radius:2px;transition:width 1s ease;}
.section-title.visible::after{width:60px;}
.about-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:32px;align-items:start;}
.about-avatar{aspect-ratio:1;border-radius:20px;background:linear-gradient(135deg,rgba(0,191,255,.1),rgba(30,144,255,.05));border:1px solid var(--glass-border);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.about-avatar::after{content:'';position:absolute;top:-40%;left:0;width:100%;height:35%;background:linear-gradient(to bottom,transparent,rgba(0,191,255,.07),transparent);animation:scanLine 3s linear infinite;}
@keyframes scanLine{from{top:-40%}to{top:110%}}
.about-card{padding:36px;}
.about-card h3{font-family:'Orbitron',monospace;font-size:1.2rem;color:var(--accent);margin-bottom:18px;}
.about-card p{font-size:1.05rem;line-height:1.8;color:var(--muted);margin-bottom:20px;}
.about-details{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:8px;}
.detail-item{display:flex;flex-direction:column;gap:4px;}
.detail-label{font-size:.72rem;letter-spacing:.2em;color:var(--accent);text-transform:uppercase;font-family:'Space Mono',monospace;}
.detail-val{font-size:1rem;color:var(--text);}
.stats-row{display:flex;gap:32px;flex-wrap:wrap;margin-bottom:44px;}
.stat-item{text-align:center;}
.stat-num{font-family:'Orbitron',monospace;font-size:2rem;font-weight:900;color:var(--accent);text-shadow:0 0 18px var(--glow);}
.stat-label{font-size:.75rem;letter-spacing:.18em;color:var(--muted);text-transform:uppercase;margin-top:4px;}
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;}
.skill-card{padding:30px 28px;cursor:default;}
.skill-icon{font-size:2.2rem;margin-bottom:14px;display:inline-block;transition:transform .3s;filter:drop-shadow(0 0 10px var(--glow));}
.skill-card:hover .skill-icon{transform:scale(1.3) rotate(-8deg);}
.skill-name{font-family:'Orbitron',monospace;font-size:.85rem;font-weight:700;letter-spacing:.1em;color:var(--text);margin-bottom:18px;}
.skill-bar-track{height:5px;border-radius:50px;background:rgba(255,255,255,.07);overflow:visible;position:relative;}
.skill-bar-fill{height:100%;border-radius:50px;background:linear-gradient(to right,var(--accent),var(--accent2));box-shadow:0 0 10px var(--glow);width:0;transition:width 1.4s cubic-bezier(.4,0,.2,1);position:relative;overflow:hidden;}
.skill-bar-fill::after{content:'';position:absolute;top:0;left:-60%;width:60%;height:100%;background:linear-gradient(to right,transparent,rgba(255,255,255,.4),transparent);animation:shimBar 2.2s 1.6s infinite;}
@keyframes shimBar{from{left:-60%}to{left:120%}}
.skill-pct{font-family:'Space Mono',monospace;font-size:.75rem;color:var(--accent);margin-top:8px;text-align:right;}
.projects-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:28px;}
.project-card{padding:32px;position:relative;overflow:hidden;cursor:default;}
.project-card::before{content:'';position:absolute;top:-60px;right:-60px;width:180px;height:180px;border-radius:50%;background:radial-gradient(circle,var(--glow) 0%,transparent 70%);opacity:.3;pointer-events:none;transition:opacity .3s,transform .4s;}
.project-card:hover::before{opacity:.7;transform:scale(1.4);}
.project-num{font-family:'Space Mono',monospace;font-size:.7rem;color:var(--accent);letter-spacing:.2em;margin-bottom:12px;}
.project-title{font-family:'Orbitron',monospace;font-size:1rem;font-weight:700;color:#fff;margin-bottom:12px;transition:color .2s;}
.project-card:hover .project-title{color:var(--accent);}
.project-desc{font-size:.95rem;color:var(--muted);line-height:1.7;margin-bottom:20px;}
.project-tags{display:flex;flex-wrap:wrap;gap:8px;}
.tag{padding:4px 14px;border-radius:50px;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;border:1px solid var(--glass-border);color:var(--accent);background:rgba(0,191,255,.06);font-family:'Space Mono',monospace;transition:background .2s,border-color .2s;}
.project-card:hover .tag{background:rgba(0,191,255,.12);border-color:var(--accent);}
.contact-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:32px;}
.contact-info{padding:36px;}
.contact-info h3{font-family:'Orbitron',monospace;font-size:1rem;color:var(--accent);margin-bottom:24px;}
.contact-item{display:flex;align-items:center;gap:14px;margin-bottom:22px;transition:transform .2s;}
.contact-item:hover{transform:translateX(8px);}
.contact-icon{width:44px;height:44px;border-radius:12px;background:rgba(0,191,255,.08);border:1px solid var(--glass-border);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;transition:box-shadow .2s,background .2s;}
.contact-item:hover .contact-icon{background:rgba(0,191,255,.18);box-shadow:0 0 14px var(--glow);}
.contact-item p{font-size:.8rem;color:var(--muted);margin-bottom:2px;text-transform:uppercase;letter-spacing:.15em;}
.contact-item a,.contact-item span{font-size:1rem;color:var(--text);text-decoration:none;transition:color .2s;}
.contact-item a:hover{color:var(--accent);}
.socials{display:flex;gap:14px;margin-top:32px;}
.social-btn{width:44px;height:44px;border-radius:12px;background:var(--glass-bg);border:1px solid var(--glass-border);display:flex;align-items:center;justify-content:center;font-size:1.1rem;transition:all .25s;cursor:none;text-decoration:none;}
.social-btn:hover{background:rgba(0,191,255,.14);border-color:var(--accent);box-shadow:0 0 16px var(--glow);transform:translateY(-5px) rotate(8deg);}
.contact-form{padding:36px;}
.form-group{margin-bottom:22px;}
.form-group label{display:block;font-size:.75rem;letter-spacing:.2em;color:var(--accent);text-transform:uppercase;margin-bottom:8px;font-family:'Space Mono',monospace;}
.form-group input,.form-group textarea{width:100%;padding:14px 18px;background:rgba(255,255,255,.04);border:1px solid var(--glass-border);border-radius:12px;color:var(--text);font-family:'Rajdhani',sans-serif;font-size:1rem;outline:none;transition:border-color .25s,box-shadow .25s;resize:none;}
.form-group input:focus,.form-group textarea:focus{border-color:var(--accent);box-shadow:0 0 20px var(--glow);}
.form-group textarea{height:120px;}
.btn-submit{width:100%;padding:16px;border-radius:50px;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#000;font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;border:none;cursor:none;box-shadow:0 0 24px var(--glow);transition:all .3s;position:relative;overflow:hidden;}
.btn-submit::before{content:'';position:absolute;top:-50%;left:-60%;width:200%;height:200%;background:rgba(255,255,255,.18);transform:rotate(25deg) translateX(-100%);transition:transform .5s;}
.btn-submit:hover::before{transform:rotate(25deg) translateX(100%);}
.btn-submit:hover{transform:translateY(-3px);box-shadow:0 0 48px var(--glow);}
.form-msg{margin-top:14px;text-align:center;font-size:.9rem;color:var(--accent);opacity:0;transition:opacity .3s;}
footer{position:relative;z-index:3;border-top:1px solid var(--glass-border);padding:28px 5%;display:flex;align-items:center;justify-content:space-between;background:rgba(10,10,10,.8);backdrop-filter:blur(12px);flex-wrap:wrap;gap:14px;}
footer p{font-size:.82rem;color:var(--muted);}
footer span{color:var(--accent);}
.footer-logo{font-family:'Orbitron',monospace;font-size:.9rem;font-weight:900;color:var(--accent);letter-spacing:.15em;text-shadow:0 0 12px var(--glow);}
.reveal{opacity:0;transform:translateY(32px);transition:opacity .75s ease,transform .75s ease;}
.reveal.visible{opacity:1;transform:none;}
.reveal-left{opacity:0;transform:translateX(-32px);transition:opacity .75s ease,transform .75s ease;}
.reveal-left.visible{opacity:1;transform:none;}
.reveal-right{opacity:0;transform:translateX(32px);transition:opacity .75s ease,transform .75s ease;}
.reveal-right.visible{opacity:1;transform:none;}
.type-cursor{color:var(--accent);animation:blink 1s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
#hero-role{font-family:'Rajdhani',sans-serif;font-size:clamp(1.1rem,2.5vw,1.6rem);font-weight:300;letter-spacing:.25em;color:var(--muted);text-transform:uppercase;opacity:0;animation:fadeUp .7s .7s forwards;margin-bottom:40px;min-height:2em;}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px);}to{opacity:1;transform:none;}}
@keyframes scrollPulse{0%,100%{opacity:1;transform:scaleY(1);}50%{opacity:.3;transform:scaleY(.7);}}
@media(max-width:768px){
  .nav-links{display:none;position:fixed;top:70px;left:0;right:0;flex-direction:column;gap:0;background:rgba(10,10,10,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--glass-border);padding:16px 0;}
  .nav-links.open{display:flex;}
  .nav-links li{border-bottom:1px solid rgba(255,255,255,.04);}
  .nav-links a{display:block;padding:16px 24px;}
  .hamburger{display:flex;}
  .about-grid{grid-template-columns:1fr;}
  .contact-grid{grid-template-columns:1fr;}
}
@media(max-width:500px){
  .about-details{grid-template-columns:1fr;}
  .hero-btns{flex-direction:column;align-items:center;}
}
</style>
</head>
